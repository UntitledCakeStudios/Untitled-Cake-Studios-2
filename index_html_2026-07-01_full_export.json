      "content": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <title>Untitled C🎂ke Studios | PUBLISHED</title>\n    <style>\n        body { \n            background: linear-gradient(135deg, #FF00FF, #0000FF, #800080);\n            background-attachment: fixed;\n            font-family: 'Verdana', sans-serif; padding: 0; margin: 0; color: #000; overflow: hidden;\n        }\n        .top-bar-container { position: fixed; top: 0; width: 100%; background: #D4D0C8; border-bottom: 3px outset #FFF; padding: 5px; z-index: 100; }\n        .window { border: 3px outset #FFF; background-color: #D4D0C8; padding: 2px; max-width: 1100px; margin: 70px auto 10px auto; box-shadow: 10px 10px 30px #000; }\n        .title-bar { background: linear-gradient(to right, #FF00FF, #00FFFF); color: white; padding: 4px 10px; font-weight: bold; font-size: 14px; display: flex; justify-content: space-between; }\n        .brand-header { background: #EFEFEF; padding: 25px; text-align: center; border-bottom: 2px inset #FFF; }\n        .brand-header h1 { margin: 0; font-size: 40px; font-family: 'Arial Black', sans-serif; color: #FF4500; text-shadow: 2px 2px #FFFF00; }\n        \n        .tab-container { display: flex; justify-content: center; flex-wrap: wrap; gap: 5px; }\n        .nav-btn { background: #7FFF00; border: 2px outset #FFF; padding: 8px 12px; cursor: pointer; font-weight: bold; font-size: 10px; }\n        \n        .frame { display: none; padding: 25px; background: #FFF; border: 2px inset #FFF; margin: 5px; min-height: 350px; overflow-y: auto; }\n        .frame.active { display: block; }\n        \n        h2 { font-size: 18px; border-bottom: 2px solid #FF4500; color: #8A2BE2; }\n        .stats { background: #000; color: #0F0; padding: 10px; font-family: monospace; font-size: 14px; margin-top: 15px; border: 2px inset #FFF; }\n        \n        .taskbar { position: fixed; bottom: 0; width: 100%; height: 35px; background: #D4D0C8; border-top: 3px outset #FFF; display: flex; align-items: center; padding: 0 10px; justify-content: space-between; font-weight: bold; }\n    </style>\n</head>\n<body>\n\n<div class=\"top-bar-container\">\n    <div class=\"tab-container\">\n        <button class=\"nav-btn\" onclick=\"showFrame('home')\">HOME</button>\n        <button class=\"nav-btn\" onclick=\"showFrame('projects')\">PROJECTS</button>\n        <button class=\"nav-btn\" onclick=\"showFrame('family')\">FAMILY HUB</button>\n        <button class=\"nav-btn\" onclick=\"showFrame('news')\">NEWS</button>\n        <button class=\"nav-btn\" onclick=\"showFrame('community')\">COMMUNITY</button>\n        <button class=\"nav-btn\" onclick=\"showFrame('tools')\">TOOLS</button>\n        <button class=\"nav-btn\" onclick=\"showFrame('media')\">MEDIA</button>\n    </div>\n</div>\n\n<div class=\"window\">\n    <div class=\"title-bar\"><span>Untitled_C🎂ke_Studios_MASTER.exe</span><span>_ 🗕 X</span></div>\n    <div class=\"brand-header\">\n        <h1>Untitled C🎂ke Studios</h1>\n        <p>Finn's Official Dev Workspace & Community Hangout</p>\n    </div>\n\n    <div id=\"home\" class=\"frame active\">\n        <h2>Welcome to the Studio!</h2>\n        <p>Hey everyone! I'm Finn, and I'm a 9-year-old developer doing what I love. Kids deserve to have fun, exciting games that let their imaginations run wild!</p>\n        <div class=\"stats\">\n            >> LIVE_STATS_MONITOR <<<br>\n            [ PEOPLE ACTIVE ]: 24 ONLINE<br>\n            [ TOTAL VISITS ]: 14,082<br>\n            [ SERVER STATUS ]: OPTIMIZED\n        </div>\n    </div>\n    <!-- Other frames remain consistent -->\n    <div id=\"projects\" class=\"frame\"><h2>Game Registry</h2><ul><li>Deliver Packages</li><li>Super Bit World!</li><li>V4 Movement</li></ul></div>\n    <div id=\"family\" class=\"frame\"><h2>Family Hub</h2><p>Safe, fun, and inclusive for all ages!</p></div>\n    <div id=\"news\" class=\"frame\"><h2>News</h2><p>Published & Live!</p></div>\n    <div id=\"community\" class=\"frame\"><h2>Community</h2><p>Testing sessions on weekends!</p></div>\n    <div id=\"tools\" class=\"frame\"><h2>Tools</h2><p>Studio Lite & CapCut.</p></div>\n    <div id=\"media\" class=\"frame\"><h2>Media</h2><p>Check out our latest devlogs.</p></div>\n</div>\n\n<div class=\"taskbar\">\n    <div>Finnithy_Master_Suite | 2026</div>\n    <div>PUBLISHED_BUILD_V33131</div>\n</div>\n\n<script>\n    function showFrame(id) {\n        document.querySelectorAll('.frame').forEach(f => f.classList.remove('active'));\n        document.getElementById(id).classList.add('active');\n    }\n</script>\n</body>\n</html>\n",
